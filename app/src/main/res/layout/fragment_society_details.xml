<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ── Header (consistent with all other fragments) ────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#5C8374"
        android:padding="20dp">

        <!-- Back button row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/txtDetailName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Category subtitle -->
        <TextView
            android:id="@+id/txtDetailCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#D0E8E0"
            android:textSize="13sp"
            android:layout_marginBottom="14dp"/>

        <!-- Stats row inside header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#4A7264"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/txtStatMembersCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Members"
                    android:textSize="11sp"
                    android:textColor="#D0E8E0"/>

            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:background="#6EA898"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/txtStatEventsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Events"
                    android:textSize="11sp"
                    android:textColor="#D0E8E0"/>

            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:background="#6EA898"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/txtStatAnnouncementsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Posts"
                    android:textSize="11sp"
                    android:textColor="#D0E8E0"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ── Scrollable body ──────────────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Description card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="About"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#5C8374"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/txtDetailDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingMultiplier="1.4"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- JOIN button (non-members) -->
            <Button
                android:id="@+id/btnJoinSociety"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                android:text="Apply to Join"
                android:textSize="15sp"
                android:backgroundTint="#5C8374"
                style="@style/Widget.MaterialComponents.Button"
                app:cornerRadius="10dp"
                android:visibility="gone"/>

            <!-- Pending request notice -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPendingNotice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFF8E1"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text="⏳ Your membership request is pending admin approval."
                    android:textSize="13sp"
                    android:textColor="#F57F17"/>

            </androidx.cardview.widget.CardView>

            <!-- Leave society button (members) -->
            <LinearLayout
                android:id="@+id/layoutMemberActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <Button
                    android:id="@+id/btnLeaveSociety"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Leave Society"
                    android:textSize="14sp"
                    android:backgroundTint="#FFEBEE"
                    android:textColor="#D32F2F"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="#FFCDD2"
                    app:cornerRadius="10dp"/>

            </LinearLayout>

            <!-- ── Announcements section ─────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp"
                android:layout_marginTop="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Announcements"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>

                <View
                    android:layout_width="32dp"
                    android:layout_height="3dp"
                    android:background="#5C8374"/>

            </LinearLayout>

            <TextView
                android:id="@+id/txtNoAnnouncements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No announcements yet."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingBottom="8dp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerAnnouncements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"/>

            <!-- ── Events section ────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Upcoming Events"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>

                <View
                    android:layout_width="32dp"
                    android:layout_height="3dp"
                    android:background="#5C8374"/>

            </LinearLayout>

            <TextView
                android:id="@+id/txtNoEvents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No upcoming events."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingBottom="8dp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerEvents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"/>

            <View android:layout_width="match_parent" android:layout_height="24dp"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>